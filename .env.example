# Copy this file to .env for local-only non-secret settings.
# Never commit real API keys, tokens, passwords, or private endpoints.

# Secrets should live in provider CLIs, OS credential stores, or short-lived
# session environment variables. Do not put long-lived GitHub tokens here.

# Optional: set this when a future command system supports model routing.
FACTORY_DEFAULT_MODEL_MODE=balanced

# Optional: set to the local Obsidian-style memory vault path.
FACTORY_MEMORY_VAULT=memory/vault
