{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "local-event.schema.json",
  "title": "Software Factory Local Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp_utc",
    "scope",
    "actor",
    "event_type",
    "summary",
    "source"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp_utc": {
      "type": "string"
    },
    "scope": {
      "type": "string",
      "enum": ["framework", "project"]
    },
    "project_slug": {
      "type": ["string", "null"]
    },
    "actor": {
      "type": "string"
    },
    "event_type": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "related_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
