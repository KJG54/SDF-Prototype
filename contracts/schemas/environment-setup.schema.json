{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "environment-setup.schema.json",
  "title": "Software Factory Environment Setup",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "summary",
    "environment_strategy",
    "dependency_locality",
    "development_machine",
    "target_platforms",
    "app_runtime",
    "build_runtime",
    "package_manager",
    "dependency_isolation",
    "local_services",
    "why_this_strategy",
    "required_system_tools",
    "project_local_tools_dependencies",
    "system_wide_tools_and_reasons",
    "optional_tools",
    "step_by_step_setup",
    "verification_commands",
    "beginner_notes",
    "agent_notes",
    "human_notes",
    "risks_tradeoffs",
    "approval"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "environment_strategy": { "type": "string" },
    "dependency_locality": { "type": "string" },
    "development_machine": { "type": "string" },
    "target_platforms": { "type": "array", "items": { "type": "string" } },
    "app_runtime": { "type": "string" },
    "build_runtime": { "type": "string" },
    "package_manager": { "type": "string" },
    "dependency_isolation": { "type": "string" },
    "local_services": { "type": "array", "items": { "type": "string" } },
    "why_this_strategy": { "type": "string" },
    "required_system_tools": { "type": "array" },
    "project_local_tools_dependencies": { "type": "array" },
    "system_wide_tools_and_reasons": { "type": "array" },
    "optional_tools": { "type": "array" },
    "step_by_step_setup": { "type": "array" },
    "verification_commands": { "type": "array" },
    "beginner_notes": { "type": "object", "required": ["folder_to_use", "expected_result", "what_to_tell_agent"] },
    "agent_notes": { "type": "string" },
    "human_notes": { "type": "string" },
    "risks_tradeoffs": { "type": "array", "items": { "type": "string" } },
    "approval": { "type": "object", "required": ["status", "approved_by", "approved_at"] }
  }
}
