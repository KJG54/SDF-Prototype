{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shipping-plan.schema.json",
  "title": "Software Factory Shipping Plan",
  "type": "object",
  "required": [
    "id",
    "type",
    "project",
    "shipping_target",
    "public_private",
    "prepared_for_shipping",
    "release_notes",
    "setup_run_instructions_checked",
    "secrets_private_files_check",
    "human_actions_required",
    "deferred_shipping_work",
    "final_location"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "project": { "type": "string" },
    "shipping_target": { "type": "string" },
    "public_private": { "type": "string" },
    "prepared_for_shipping": { "type": "array" },
    "release_notes": { "type": "string" },
    "setup_run_instructions_checked": { "type": "string" },
    "secrets_private_files_check": { "type": "string" },
    "human_actions_required": { "type": "array" },
    "deferred_shipping_work": { "type": "array" },
    "final_location": { "type": "string" }
  }
}
