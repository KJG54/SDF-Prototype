{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "architecture.schema.json",
  "title": "Software Factory Architecture",
  "type": "object",
  "required": [
    "id",
    "type",
    "status",
    "recommendation",
    "selected_stack",
    "stack_profile",
    "development_machine",
    "target_platforms",
    "app_runtime",
    "build_runtime",
    "package_manager_lockfile",
    "dependency_isolation_strategy",
    "local_services",
    "system_wide_tools",
    "alternatives_considered",
    "rationale",
    "structure_overview",
    "components",
    "data_storage",
    "integrations",
    "security_privacy",
    "cost_notes",
    "deployment_shipping_target",
    "risks_tradeoffs",
    "approval"
  ],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "status": { "type": "string" },
    "recommendation": { "type": "string" },
    "selected_stack": { "type": "array", "items": { "type": "string" } },
    "stack_profile": { "type": "object", "required": ["profile", "why_it_fits", "differences_from_profile"] },
    "development_machine": { "type": "string" },
    "target_platforms": { "type": "array", "items": { "type": "string" } },
    "app_runtime": { "type": "string" },
    "build_runtime": { "type": "string" },
    "package_manager_lockfile": { "type": "string" },
    "dependency_isolation_strategy": { "type": "string" },
    "local_services": { "type": "array", "items": { "type": "string" } },
    "system_wide_tools": { "type": "array" },
    "alternatives_considered": { "type": "array" },
    "rationale": { "type": "string" },
    "structure_overview": { "type": "string" },
    "components": { "type": "array" },
    "data_storage": { "type": "string" },
    "integrations": { "type": "array" },
    "security_privacy": { "type": "string" },
    "cost_notes": { "type": "string" },
    "deployment_shipping_target": { "type": "string" },
    "risks_tradeoffs": { "type": "array", "items": { "type": "string" } },
    "approval": { "type": "object", "required": ["status", "approved_by", "approved_at"] }
  }
}
